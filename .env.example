# LUL Terminal — environment template
# Copy to .env and adjust before first start:
#   Windows:  copy .env.example .env
#   Linux:    cp .env.example .env
#
# The app self-configures on first start (admin account, data dirs, vault key).
# Manual seed scripts are optional.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Session cookie Secure flag: auto when PUBLIC_BASE_URL=https://… — force with COOKIE_SECURE=1|0

# Required in production behind nginx, Caddy, Cloudflare, etc.
# Enables real client IPs for rate limits.
TRUST_PROXY=0
# Comma-separated proxy hop IPs allowed to set X-Forwarded-* headers (default: loopback).
# TRUSTED_PROXY_IPS=127.0.0.1,::1

# Canonical public origin for paste/image/referral URLs in API responses.
# PUBLIC_BASE_URL=https://terminal.example.com
#
# When TRUST_PROXY=1, X-Forwarded-Host is only trusted if listed here
# (or derived from PUBLIC_BASE_URL).
# ALLOWED_PUBLIC_HOSTS=terminal.example.com,www.terminal.example.com

# ── Redis (optional — multi-instance / load balancer) ─────────────────────────
# REDIS_URL=redis://127.0.0.1:6379
# RATE_LIMIT_BACKEND=auto
# GUEST_VIEW_DEDUP_BACKEND=auto

# ── Auth bootstrap (first run only, empty database) ───────────────────────────
# If unset, a strong random password is generated and written to:
#   data/auth/admin-credentials.json  (gitignored — never commit)
# SEED_ADMIN_PASSWORD=your-strong-admin-password-here
# SEED_ADMIN_EMAIL=admin@example.com

# ── Premium vault encryption ──────────────────────────────────────────────────
# If unset, a key is auto-generated at data/secrets/premium-vault.key on first start.
# Set explicitly in production and back it up — losing it makes vault data unreadable.
# PREMIUM_VAULT_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────
# GEMINI_API_KEY=
# DISABLE_HMR=true
