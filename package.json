{
  "name": "lul-terminal",
  "private": true,
  "version": "3.48.1",
  "description": "Self-hosted community platform: auth, arcade, paste, image host, tools & admin",
  "repository": {
    "type": "git",
    "url": "https://github.com/LULdev/lul-terminal-prod.git"
  },
  "homepage": "https://github.com/LULdev/lul-terminal-prod#readme",
  "bugs": {
    "url": "https://github.com/LULdev/lul-terminal-prod/issues"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18"
  },
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build && node scripts/verify-build-chunks.mjs",
    "seed:proxy-sources": "node scripts/seed-proxy-sources.mjs",
    "seed:persona-db": "node scripts/seed-persona-database.mjs",
    "seed:news": "node scripts/seed-news-articles.mjs",
    "bootstrap": "node scripts/seed-auth-database.mjs",
    "bootstrap:reset": "node scripts/seed-auth-database.mjs --reset",
    "seed:auth": "node scripts/seed-auth-database.mjs",
    "seed:auth:reset": "node scripts/seed-auth-database.mjs --reset",
    "start": "node server/start.mjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vercel/analytics": "^2.0.1",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^11.8.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.15.0",
    "https-proxy-agent": "^9.1.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "qrcode": "^1.5.4",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.9.1",
    "redis": "^4.7.1",
    "socks-proxy-agent": "^10.1.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/qrcode": "^1.5.6",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
